# Secrets
.env
.env.local
.env.*.local

# Runtime data (per-user / per-host) — keep `data/` itself for structure but
# never commit user-specific contents. Anything generated by running the
# dashboard belongs in here and is per-user.
data/settings.json
data/bots.json
data/memory/
data/msa-cache/
data/snapshots/
data/diagnostics/
data/logs/
data/overnight/state.json
data/overnight/slots.json
data/overnight/overnight.jsonl
data/overnight/manual-restarts.jsonl
data/overnight/*.log
data/overnight/*.log.err
data/overnight/*.out
data/overnight/*.err
data/overnight/*.pid
data/overnight/cloudflared.log
data/dashboard-heartbeat
data/mc-test-slot*/
data/mc-test*.out
data/mc-control.out
data/dev-server.log
data/dev-server-err.log

# The bundled vanilla Minecraft server lives under data/minecraft-server/
# when downloaded by `npm run setup`. Don't redistribute Mojang binaries.
data/minecraft-server/

# Personal session captures (vault content)
AI/

# Local-only tooling (CDP screenshot drivers, ad-hoc scripts not for distribution)
.tools/

# Editor / OS
node_modules/
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Build artifacts (none today, but pre-emptive)
dist/
build/
coverage/
*.tsbuildinfo

# Top-level convenience logs from running detached
server.log
server.err

# Personal research data (Forage experiments) — never ship
data/forage-pilot/
