# Copy to .env and fill in. The .env file is gitignored.

# --- LLM provider (required for the brain) -------------------------------
# Warden talks to any OpenAI-compatible chat API. Two ways to configure it:
#
# 1. Point it at any endpoint directly:
#      LLM_API_KEY    your provider's key
#      LLM_BASE_URL   the OpenAI-compatible endpoint
#      LLM_MODEL      the model id
#
# 2. Or name a known provider and just supply the key (base URL + a default
#    model are filled in for you):
#      LLM_PROVIDER=groq
#      LLM_API_KEY=gsk_...
#
# Known LLM_PROVIDER values (default model in parentheses):
#   cerebras   (qwen-3-235b-a22b-instruct-2507)   <- default
#   openai     (gpt-4o-mini)
#   openrouter (qwen/qwen3-235b-a22b-2507)
#   groq       (llama-3.3-70b-versatile)
#   together   (Qwen/Qwen2.5-72B-Instruct-Turbo)
#   deepseek   (deepseek-chat)
#   mistral    (mistral-large-latest)
#   xai        (grok-2-latest)
#   ollama     (qwen2.5:7b, no key needed — runs locally)
#
# Set LLM_MODEL to override the default for any provider. For a custom
# endpoint (a proxy, a self-hosted gateway), set LLM_BASE_URL and LLM_MODEL.

LLM_API_KEY=your_key_here
# LLM_PROVIDER=cerebras
# LLM_BASE_URL=https://api.cerebras.ai/v1
# LLM_MODEL=qwen-3-235b-a22b-instruct-2507

# Without a key set, bots connect and stand idle — the dashboard still works.
# You can also paste the key into the dashboard at runtime instead of here.

# Legacy: CEREBRAS_API_KEY is still honored as an alias for LLM_API_KEY.
# CEREBRAS_API_KEY=your_key_here

# --- optional ---

# HTTP server bind address. 127.0.0.1 keeps the dashboard local-only;
# use 0.0.0.0 to expose on the LAN.
# HOST=127.0.0.1

# HTTP / WebSocket port for the dashboard.
# PORT=8080

# Where bots.json, settings.json, memory/, snapshots/, etc. live.
# Override to share a data directory across hosts (e.g. a NAS mount).
# DATA_DIR=./data
