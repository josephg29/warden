# Copy to .env and fill in. The .env file is gitignored.

# Required for the brain (LLM-driven decision loop) to run.
# Get one at https://cloud.cerebras.ai (free tier covers light experiments).
# Without this set, bots connect and stand idle — the dashboard still works.
CEREBRAS_API_KEY=your_key_here

# --- optional ---

# HTTP server bind address. 127.0.0.1 keeps the dashboard local-only;
# use 0.0.0.0 to expose on the LAN.
# HOST=127.0.0.1

# HTTP / WebSocket port for the dashboard.
# PORT=8080

# Where bots.json, settings.json, memory/, snapshots/, etc. live.
# Override to share a data directory across hosts (e.g. a NAS mount).
# DATA_DIR=./data
